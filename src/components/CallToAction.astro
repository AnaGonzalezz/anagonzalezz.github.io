---
import svgPinkStar from '../assets/pink-star.svg'
import Button from './Button.astro'
import { author } from '../sample'
import { t, type Lang } from '../lib/i18n'

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props
const c = t[lang].cta
---

<section class="px-3" id="hire">
    <div class="max-w-3xl mx-auto bg-white text-center flex flex-col gap-4 border-3 shadow-[8px_8px_0px_rgba(0,0,0,0.3)] relative p-10">
     <h1 class="text-3xl">{c.heading}</h1>
     <p class="text-lg max-w-lg mx-auto">{c.subtitle}</p>
     <div class="flex justify-center">
       <Button text={c.button} link={author.email} target="_blank" />
     </div>
     <img src={svgPinkStar.src} alt="svg" width="80" class="absolute -top-10 right-20" />
    </div>
  </section>
