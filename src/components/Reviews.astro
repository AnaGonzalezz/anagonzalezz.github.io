---
import svgNew from '../assets/new.svg'
import { t, type Lang } from '../lib/i18n'

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props
const v = t[lang].volunteering

const rotations = [`rotate-2 -translate-y-6`, `-rotate-2 -translate-x-8 z-5`, `rotate-1 translate-x-4 z-5`]
const certRotations = [`rotate-1`, `-rotate-1`, `rotate-2`]
---

<section id="volunteering">
  <div class="max-w-4xl mx-auto pb-20 px-10 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="flex relative">
        <h1 class="text-3xl">{v.heading}</h1>
        <img src={svgNew.src} alt="arrow" width="40" class="absolute -right-3 md:-right-10 bottom-0" />
      </div>
    </div>

    <h2 class="text-lg font-bold mt-12 mb-6 uppercase tracking-widest">{v.vol_label}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 py-4 gap-6">
      {v.items.map((item, i) => (
        <div class={`flex flex-col gap-3 p-5 bg-white border-2 shadow-[6px_6px_0px_rgba(0,0,0,0.3)] ${rotations[i]}`}>
          <div>
            <h3 class="font-bold text-base">{item.org}</h3>
            <p class="text-sm font-medium">{item.role}</p>
            <p class="text-xs text-gray-500 mt-0.5">{item.period}</p>
          </div>
          <p class="text-sm">{item.desc}</p>
        </div>
      ))}
    </div>

    <h2 class="text-lg font-bold mt-14 mb-6 uppercase tracking-widest">{v.cert_label}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {v.certs.map((cert, i) => (
        <div class={`flex flex-col gap-1 p-5 bg-[var(--blue)] border-2 shadow-[4px_4px_0px_rgba(0,0,0,0.3)] ${certRotations[i]}`}>
          <span class="text-xs font-bold uppercase tracking-widest">Certificate</span>
          <h3 class="font-bold text-base mt-1">{cert.name}</h3>
          <p class="text-sm">{cert.issuer}</p>
          <p class="text-xs text-gray-600 mt-1">{cert.date}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 p-5 border-2 border-black bg-[var(--yellow)] shadow-[4px_4px_0px_rgba(0,0,0,0.3)] max-w-md">
      <span class="text-xs font-bold uppercase tracking-widest">{v.award_label}</span>
      <h3 class="font-bold text-base mt-1">{v.award.name}</h3>
      <p class="text-sm">{v.award.issuer}</p>
    </div>
  </div>
</section>
