---
import { t, type Lang } from '../lib/i18n'
import svgPinkStar from '../assets/pink-star.svg'

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props
const ed = t[lang].education
---

<section class="relative px-3 md:px-10 py-16 overflow-hidden" id="education">
  <img src={svgPinkStar.src} alt="" width="70" class="absolute -left-8 top-4 hidden md:block" />

  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-medium mb-10">{ed.heading}</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Degree -->
      <div class="bg-white border-2 border-black p-6 shadow-[6px_6px_0px_rgba(0,0,0,0.3)]">
        <span class="text-xs font-bold uppercase tracking-widest">B.Sc.</span>
        <h2 class="text-2xl font-bold mt-2">{ed.degree}</h2>
        <p class="text-lg mt-1">{ed.university}</p>
        <p class="text-sm text-gray-600 mt-1">{ed.period}</p>
      </div>

      <!-- Languages -->
      <div class="border-2 border-black p-6 bg-[var(--main-bg)] shadow-[6px_6px_0px_rgba(0,0,0,0.3)]">
        <span class="text-xs font-bold uppercase tracking-widest">{ed.lang_heading}</span>
        <div class="flex flex-col gap-3 mt-3">
          {ed.langs.map(l => (
            <div class="flex items-center justify-between border-b border-black/20 pb-2 last:border-none last:pb-0">
              <span class="font-medium">{l.name}</span>
              <span class="text-sm bg-[var(--yellow)] border border-black px-2 py-0.5 font-mono">{l.level}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
